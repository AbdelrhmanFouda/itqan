# Firebase Web SDK configuration.
# Copy this file to .env.local and fill in the values from the Firebase console:
#   Project settings → General → Your apps → Web app → "SDK setup and configuration"
#
# These are NEXT_PUBLIC_ (exposed to the browser). That is normal for Firebase web
# config — access is controlled by Firestore security rules, not by hiding these keys.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
