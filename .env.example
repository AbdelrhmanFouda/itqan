# Firebase Web SDK configuration.
# Copy this file to .env.local and fill in the values from the Firebase console:
#   Project settings → General → Your apps → Web app → "SDK setup and configuration"
#
# These are NEXT_PUBLIC_ (exposed to the browser). That is normal for Firebase web
# config — access is controlled by Firestore security rules, not by hiding these keys.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Google Sheets (read-only) — powers the dashboard Molds Register.
# Server-side only (NOT NEXT_PUBLIC), so the API key stays off the browser.
# Setup steps are in SHEETS_SETUP.md. Leave blank until your sheet is ready —
# the page just shows a "not connected yet" notice until then.
# ---------------------------------------------------------------------------
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_API_KEY=
# Tab that holds the per-mold rows (defaults to "All Molds" if left blank):
GOOGLE_SHEETS_MOLDS_TAB=All Molds

# --- Editing + private sheet via Apps Script (recommended) ---
# Deploy apps-script.gs as a Web app (steps are in its header), then set its URL
# here. This enables saving from the dashboard AND lets the sheet be fully
# private — when set, reads also go through the script, so the public link /
# API key above are no longer needed. The secret must match TOKEN in apps-script.gs.
GOOGLE_APPS_SCRIPT_URL=
GOOGLE_APPS_SCRIPT_SECRET=itqan_bridge_8fK2pXq9Lm4Rv7Tz1Wn6Bd
